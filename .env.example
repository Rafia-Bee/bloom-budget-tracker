# Flask Configuration
FLASK_APP=backend/app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-change-this-in-production

# Database
DATABASE_URL=sqlite:///bloom.db

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key-change-this

# CORS Configuration (comma-separated list of allowed origins)
# For development: http://localhost:5173
# For production: https://the-bloom-tracker.netlify.app
CORS_ORIGINS=http://localhost:5173

# Application Settings
CREDIT_CARD_LIMIT=1500
SIMULATE_COLD_START="false"

# Email Configuration (SendGrid)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=no-reply@bloom-tracker.app
FRONTEND_URL=https://bloom-tracker.app
